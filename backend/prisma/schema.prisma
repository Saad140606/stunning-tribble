generator client {
  provider = "prisma-client-js"
}

  datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
  }

  // Category and status will be stored as strings for SQLite compatibility

 model User {
  id           Int      @id @default(autoincrement())
  full_name    String
  email        String   @unique
  phone        String
  password_hash String
  city         String
  cnic         String?
  role         String   @default("citizen")
  is_verified  Boolean  @default(false)
  is_active    Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  complaints   Complaint[]
  refreshTokens RefreshToken[]
 }

 model RefreshToken {
  id         Int      @id @default(autoincrement())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     Int
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())
  revoked    Boolean  @default(false)
 }

 model Complaint {
  id          Int       @id @default(autoincrement())
  user        User      @relation(fields: [userId], references: [id])
  userId      Int
  latitude    Float
  longitude   Float
    // location column removed for SQLite
    category    String   // e.g., 'POTHOLE', 'GARBAGE', etc.
    severity    Int      // weight calculated on backend (1‑5)
    status      String   @default("PENDING")
  description String?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt
 }
